{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base", "helpers:pinGitHubActionDigests"],
  "labels": ["dependencies", "renovate"],
  "rangeStrategy": "bump",
  "postUpdateOptions": ["gomodTidy", "npmDedupe"],
  "ignoreDeps": [],
  "packageRules": [
    {
      "description": "Group all GitHub Action pin updates into a single PR to reduce noise",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions-pins"
    },
    {
      "description": "Group minor and patch updates for Rust crates to prevent PR flooding",
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "rust-minor-updates",
      "automerge": false
    },
    {
      "description": "Separate PRs for Major updates (breaking changes) so you check them carefully",
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["major"],
      "groupName": null
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 5am on monday"]
  }
}
